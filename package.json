{
  "name": "ntfy-app",
  "title": "Ntfy App",
  "version": "0.1.2",
  "description": "Desktop client for ntfy.sh and self-hosted ntfy instances on Windows, Linux, and macOS. Built with Rust, Tauri, and Next.js.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Rubix Studios <hello@rubixstudios.com.au> (https://rubixstudios.com.au)",
  "homepage": "https://rubixstudios.com.au",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubix-studios-pty-ltd/ntfy-app.git"
  },
  "bugs": {
    "url": "https://github.com/rubix-studios-pty-ltd/ntfy-app/issues"
  },
  "maintainers": [
    {
      "name": "Rubix Studios",
      "email": "hello@rubixstudios.com.au",
      "url": "https://rubixstudios.com.au"
    }
  ],
  "keywords": [
    "ntfy",
    "ntfy.sh",
    "notifications",
    "desktop",
    "client",
    "tauri",
    "rust",
    "nextjs",
    "react",
    "typescript",
    "cross-platform",
    "windows",
    "linux",
    "macos"
  ],
  "scripts": {
    "dev": "tauri dev",
    "dev:ui": "next dev -p 5173",
    "build": "tauri build",
    "build:ui": "next build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "release:new": "node scripts/release.mjs",
    "typecheck": "tsc --noEmit",
    "update": "pnpm self-update && pnpm update --latest --recursive && pnpm install && pnpm prune && pnpm dedupe"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "24.x || 25.x",
    "pnpm": ">=10"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "shadcn": "^4.8.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
